# Production Environment Configuration
# ไฟล์นี้ใช้สำหรับ Production Build (npm run build)

# Base URL สำหรับ Vue App (ต้องตรงกับ path บน server)
VUE_APP_BASE_URL=/intsys/onsiteservice/

# API Base URL (absolute path สำหรับ production)
VUE_APP_API_BASE_URL=/intsys/onsiteservice/onsite_backend/api

# Environment Mode
NODE_ENV=production
